# Copy to .env and fill in. .env is gitignored — your creds never get committed.
#
# Connect as the READ-ONLY role (see SETUP.md), NOT the superuser. This is the
# safety wall: even if the model emits a write, the DB itself rejects it.
#
# Supabase: Project Settings → Database → Connection string → "Direct connection"
# (port 5432, NOT the 6543 pooler). SSL is required.
DATABASE_URL=postgresql://sibyl_ro:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Optional model overrides (defaults shown) — the "swap seam".
# SIBYL_CHAT_MODEL=qwen2.5-coder
# SIBYL_EMBED_MODEL=nomic-embed-text

# Context window in tokens. Ollama's own default is only 2048; we raise it to 8192
# so the schema + conversation fit. qwen2.5-coder supports up to 32768.
# SIBYL_NUM_CTX=8192
