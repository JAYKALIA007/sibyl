{
  "name": "sibyl-cli",
  "version": "0.7.0",
  "description": "Ask your database in plain English — a from-scratch, local-first natural-language-to-SQL tool.",
  "type": "module",
  "bin": {
    "sibyl": "dist/sibyl.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "keywords": [
    "sql",
    "postgres",
    "natural-language",
    "text-to-sql",
    "cli",
    "ollama",
    "local-first"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JAYKALIA007/sibyl.git"
  },
  "homepage": "https://github.com/JAYKALIA007/sibyl#readme",
  "bugs": {
    "url": "https://github.com/JAYKALIA007/sibyl/issues"
  },
  "scripts": {
    "ollama:check": "tsx ollama.ts",
    "db:check": "node --import tsx --env-file-if-exists=.env db.ts",
    "schema:ddl": "node --import tsx --env-file-if-exists=.env introspect.ts",
    "nl2sql:check": "node --import tsx --env-file-if-exists=.env nl2sql.ts",
    "core:check": "node --import tsx --env-file-if-exists=.env core.ts",
    "sibyl": "node --import tsx --env-file-if-exists=.env cli.ts",
    "eval": "node --import tsx --env-file-if-exists=.env evals/run.ts",
    "eval:multi": "node --import tsx --env-file-if-exists=.env evals/run-conversations.ts",
    "server": "node --import tsx --env-file-if-exists=.env server.ts",
    "web:build": "pnpm --filter sibyl-web build",
    "build:cli": "tsup && node scripts/copy-web-dist.mjs",
    "start": "pnpm run web:build && pnpm run server",
    "prepublishOnly": "pnpm run web:build && pnpm run build:cli",
    "test": "node --import tsx --test *.test.ts",
    "sidecar:build": "tsup --config tsup.sidecar.config.ts",
    "desktop:build-web": "VITE_API_URL=http://127.0.0.1:47821/api pnpm --filter sibyl-web build",
    "desktop:dev-web": "VITE_API_URL=http://127.0.0.1:47821/api pnpm --filter sibyl-web dev",
    "desktop:prep": "pnpm run sidecar:build && pnpm run desktop:build-web",
    "tauri": "tauri"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.1.3",
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/express": "^4.17.25",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "express": "^4.22.2",
    "pg": "^8.22.0"
  }
}
