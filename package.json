{
  "name": "sibyl",
  "version": "0.1.0",
  "description": "Ask your database in plain English — a from-scratch, local-first natural-language-to-SQL tool.",
  "type": "module",
  "scripts": {
    "ollama:check": "tsx ollama.ts",
    "db:check": "node --import tsx --env-file=.env db.ts",
    "schema:ddl": "node --import tsx --env-file=.env introspect.ts",
    "nl2sql:check": "node --import tsx --env-file=.env nl2sql.ts",
    "core:check": "node --import tsx --env-file=.env core.ts",
    "sibyl": "node --import tsx --env-file=.env cli.ts",
    "test": "node --import tsx --test *.test.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0"
  }
}
