{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sibyl",
  "version": "0.8.0",
  "identifier": "com.sibyl.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "pnpm run sidecar:build && pnpm run desktop:dev-web",
      "wait": false
    },
    "beforeBuildCommand": "pnpm run desktop:prep"
  },
  "app": {
    "windows": [
      {
        "title": "Sibyl",
        "width": 1040,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["sidecar/sibyl-server.mjs", "bin/node"],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
